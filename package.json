{
  "name": "farahidi",
  "version": "0.2.0",
  "description": "Arabic morphological analyzer — a pure-JS/TypeScript port of AlKhalil Morpho Sys 2",
  "keywords": [
    "arabic",
    "morphology",
    "nlp",
    "morphological-analyzer",
    "lemmatizer",
    "stemmer",
    "alkhalil"
  ],
  "license": "GPL-3.0-or-later",
  "author": "Wael Tellat <wael.tellat@gmail.com>",
  "homepage": "https://github.com/forzagreen/farahidi-js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/forzagreen/farahidi-js.git"
  },
  "bugs": {
    "url": "https://github.com/forzagreen/farahidi-js/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "scripts": {
    "copy-data": "node scripts/copy-data.mjs",
    "build": "tsup && npm run copy-data",
    "build:demo": "npm run build && node scripts/build-demo.mjs",
    "serve:demo": "node scripts/serve-demo.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"{src,test,scripts,demo}/**/*.{ts,mjs}\"",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.14.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.0"
  }
}
